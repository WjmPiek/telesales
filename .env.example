SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://user:password@localhost:5432/martins
BASE_URL=http://localhost:5000
GMAIL_SMTP_USER=yourgmail@gmail.com
GMAIL_SMTP_PASSWORD=your-app-password
MAIL_FROM=Martin's Funerals <yourgmail@gmail.com>
UPLOAD_FOLDER=/var/data/uploads

# Keep 1 for first test deployments only. Set to 0 after migrations are ready.
AUTO_CREATE_TABLES=1

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-a-temporary-password

# Optional reminders / automation settings
REMINDER_FROM_EMAIL=reminders@martinsdirect.com
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Recommended production setting after migrations have run successfully
# AUTO_CREATE_TABLES=0

# Meta WhatsApp Cloud API
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=meta
META_APP_ID=
META_APP_SECRET=
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v25.0
WHATSAPP_VERIFY_TOKEN=replace-with-a-long-random-secret
BASE_URL=https://your-render-service.onrender.com

# TeleSales WhatsApp automation
ENABLE_WHATSAPP_SCHEDULER=1
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
